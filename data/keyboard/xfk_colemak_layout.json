        "name": "leader-comma-map"
      },
      "-": "xah-show-formfeed-as-line",
      "3": "delete-window",
      "4": "split-window-right",
      "5": "balance-windows",
      "6": "xah-upcase-sentence",
      "9": "ispell-word",
      "a": "mark-whole-buffer",
      "x": "end-of-buffer",
      "s": "beginning-of-buffer",
      "j": "multi-cursors",
      "t": "xah-search-current-word",
      "l": "xah-close-current-buffer",
      "n": {
        "is_prefix": true,
        "name": "leader-h-map"
      },
      "p": "kill-line",
      "c": "xah-copy-all-or-region",
      "v": "consult-yank-from-kill-ring",
      "h": "recenter-top-bottom",
      "m": "dired-jump",
      "i": {
        "is_prefix": true,
        "name": "leader-n-map"
      },
      "y": "exchange-point-and-mark",
      "g": {
        "is_prefix": true,
        "name": "leader-r-map"
      },
      "r": "save-buffer",
      "e": {
        "is_prefix": true,
        "name": "leader-t-map"
      },
      "k": "navigate-filesystem",
      ",": "xah-toggle-previous-letter-case",
      "j": "xah-show-kill-ring"
    }
