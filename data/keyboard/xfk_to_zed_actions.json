{
  "name": "Xah-Fly-Keys to Zed Action Equivalence Map",
  "description": "Maps Emacs actions from XFK to Zed actions, with an importance ranking (1=highest).",
  "action_map": {
    "backward-char": { "zed_action": "editor::MoveLeft", "importance": 1 },
    "forward-char": { "zed_action": "editor::MoveRight", "importance": 1 },
    "previous-line": { "zed_action": "editor::MoveUp", "importance": 1 },
    "next-line": { "zed_action": "editor::MoveDown", "importance": 1 },
    "backward-word": { "zed_action": "editor::MoveToPreviousWordStart", "importance": 1 },
    "forward-word": { "zed_action": "editor::MoveToNextWordStart", "importance": 1 },
    "xah-beginning-of-line-or-block": { "zed_action": "editor::MoveToBeginningOfLine", "importance": 1 },
    "xah-end-of-line-or-block": { "zed_action": "editor::MoveToEndOfLine", "importance": 1 },
    "xah-fly-insert-mode-activate": { "zed_action": "workspace::SwitchMode", "zed_action_args": ["Insert"], "importance": 1 },
    "undo": { "zed_action": "editor::Undo", "importance": 1 },
    "xah-copy-line-or-region": { "zed_action": "editor::CopyLine", "importance": 1 },
    "xah-paste-or-paste-previous": { "zed_action": "editor::Paste", "importance": 1 },
    "xah-cut-line-or-region": { "zed_action": "editor::CutLine", "importance": 1 },
    "execute-extended-command": { "zed_action": "workspace::NewCommandPalette", "importance": 1 },
    "xah-reformat-lines": { "zed_action": "editor::Format", "importance": 1 },
    "backward-kill-word": { "zed_action": "editor::DeletePreviousWord", "importance": 1 },
    "xah-comment-dwim": { "zed_action": "editor::ToggleComments", "importance": 1 },
    "hippie-expand": { "zed_action": "editor::Complete", "importance": 1 },
    "xah-delete-left-char-or-selection": { "zed_action": "editor::DeleteBackward", "importance": 1 },
    "kill-word": { "zed_action": "editor::DeleteNextWord", "importance": 1 },
    "open-line": { "zed_action": "editor::InsertNewline", "importance": 1 },
    "set-mark-command": { "zed_action": "editor::ToggleSelectionAnchor", "importance": 1 },
    "xah-goto-matching-bracket": { "zed_action": "editor::GoToMatchingBracket", "importance": 1 },
    "save-buffer": { "zed_action": "workspace::Save", "importance": 2 },
    "find-file": { "zed_action": "workspace::NewFileFinder", "importance": 2 },
    "find-file-in-project": { "zed_action": "workspace::NewFileFinder", "importance": 3 },
    "consult-buffer": { "zed_action": "workspace::NewBufferFinder", "importance": 3 },
    "switch-to-buffer": { "zed_action": "workspace::NewBufferFinder", "importance": 2 },
    "deadgrep": { "zed_action": "project_search::Deploy", "importance": 3 },
    "consult-line": { "zed_action": "buffer_search::Deploy", "importance": 3 },
    "phi-search": { "zed_action": "project_search::Deploy", "importance": 1 },
    "query-replace": { "zed_action": "project_search::Deploy", "zed_action_args": [{"replace": true}], "importance": 2 },
    "xah-search-current-word": { "zed_action": "editor::FindNext", "importance": 2 },
    "xah-select-line": { "zed_action": "editor::SelectLine", "importance": 1 },
    "xah-extend-selection": { "zed_action": "editor::SelectNext", "importance": 1 },
    "xah-select-block": { "zed_action": "editor::SelectContainingBracket", "importance": 1 },
    "xah-select-text-in-quote": { "zed_action": "editor::SelectInsideQuotes", "importance": 1 },
    "mc/mark-next-like-this": { "zed_action": "editor::SelectNextMatch", "importance": 3 },
    "mc/mark-previous-like-this": { "zed_action": "editor::SelectPreviousMatch", "importance": 3 },
    "mc/mark-all-like-this": { "zed_action": "editor::SelectAllMatches", "importance": 3 },
    "delete-other-windows": { "zed_action": "pane::CloseOtherPanes", "importance": 1 },
    "split-window-below": { "zed_action": "pane::NewPane", "importance": 1 },
    "split-window-right": { "zed_action": "pane::SplitRight", "importance": 2 },
    "xah-next-window-or-frame": { "zed_action": "workspace::ActivateNextPane", "importance": 1 },
    "other-frame": { "zed_action": "workspace::ActivateNextPane", "importance": 1 },
    "delete-window": { "zed_action": "pane::CloseActivePane", "importance": 2 },
    "mark-whole-buffer": { "zed_action": "editor::SelectAll", "importance": 2 },
    "beginning-of-buffer": { "zed_action": "editor::MoveToBeginningOfDocument", "importance": 2 },
    "end-of-buffer": { "zed_action": "editor::MoveToEndOfDocument", "importance": 2 },
    "xah-close-current-buffer": { "zed_action": "workspace::CloseActiveItem", "importance": 2 },
    "dired-jump": { "zed_action": "project_panel::ToggleFocus", "importance": 2 },
    "projectile-switch-project": { "zed_action": "project_panel::ToggleFocus", "importance": 3 },
    "xah-pop-local-mark-ring": { "zed_action": "editor::GoBack", "importance": 1 },
    "delete-char": { "zed_action": "editor::Delete", "importance": 1 },
    "xah-delete-current-text-block": { "zed_action": "editor::DeleteBlock", "importance": 1 },
    "consult-imenu": { "zed_action": "outline::Toggle", "importance": 1 },
    "magit-find-file": { "zed_action": "git::OpenGitFiles", "importance": 3 },
    "recenter-top-bottom": { "zed_action": "editor::Recenter", "importance": 2 },
    "kill-line": { "zed_action": "editor::DeleteLine", "importance": 2 },
    "xah-copy-all-or-region": { "zed_action": ["editor::SelectAll", "editor::Copy"], "importance": 2 },
    "xah-cut-all-or-region": { "zed_action": ["editor::SelectAll", "editor::Cut"], "importance": 2 },
    "consult-yank-from-kill-ring": { "zed_action": "editor::ShowClipboard", "importance": 2 },
    "xah-show-kill-ring": { "zed_action": "editor::ShowClipboard", "importance": 2 }
  }
}
